# BEAR Parlor — example environment configuration
# Copy to .env and fill in the values you need.
#
# LLM auto-detection priority:
#   1. BEAR_LLM_BASE_URL (if set, used directly)
#   2. LM Studio probe: LM_STUDIO_URL → localhost:1234 → WSL gateway
#   3. Ollama probe: OLLAMA_HOST → localhost:11434 → WSL gateway
#   4. OpenAI → Anthropic → Gemini (first available SDK + key wins)

# ---------------------------------------------------------------------------
# Hugging Face (required for first-time embedding model download)
# ---------------------------------------------------------------------------
# HF_TOKEN=hf_...

# ---------------------------------------------------------------------------
# API keys (set whichever backend you want to use)
# ---------------------------------------------------------------------------

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=...

# ---------------------------------------------------------------------------
# LM Studio (local — Yellow hat uses nvidia/nemotron-3-super)
# ---------------------------------------------------------------------------
# Auto-detected in WSL2. Override if needed.
# LM_STUDIO_URL=http://127.0.0.1:1234/v1

# ---------------------------------------------------------------------------
# Ollama (local — optional alternative)
# ---------------------------------------------------------------------------
# Override the default localhost:11434 if Ollama runs elsewhere.
# OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# Mathpix (optional — better PDF extraction for scientific papers)
# ---------------------------------------------------------------------------
# MATHPIX_APP_ID=...
# MATHPIX_APP_KEY=...

# ---------------------------------------------------------------------------
# BEAR LLM config (optional overrides)
# ---------------------------------------------------------------------------
# Force a specific backend: lmstudio, ollama, openai, anthropic, gemini
# BEAR_LLM_BACKEND=anthropic

# Force a specific model
# BEAR_LLM_MODEL=claude-haiku-4-5-20251001

# Force a specific base URL (e.g. local OpenAI-compatible server)
# BEAR_LLM_BASE_URL=http://localhost:11434/v1

# LLM temperature (default: 0.7)
# BEAR_LLM_TEMPERATURE=0.7

# ---------------------------------------------------------------------------
# BEAR retrieval config (optional overrides)
# ---------------------------------------------------------------------------
# Embedding model: "hash" (fast, no semantics) or a sentence-transformer name
# BEAR_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Number of instructions to retrieve per query (default: 10)
# BEAR_DEFAULT_TOP_K=10

# Minimum similarity threshold for retrieval (default: 0.3)
# BEAR_DEFAULT_THRESHOLD=0.3

# Weight given to instruction priority vs semantic similarity (default: 0.3)
# BEAR_PRIORITY_WEIGHT=0.3
